[
    {
        "field": "npcid",
        "annotation": "NPC 編號",
        "description": "NPC/怪物的唯一識別碼，對應 spawnlist 的 npc_templateid 及 droplist 的 mobId。"
    },
    {
        "field": "name",
        "annotation": "NPC 名稱",
        "description": "NPC 的名稱 (一般文字，如：侏儒、物品升級專員)"
    },
    {
        "field": "nameid",
        "annotation": "NPC 名稱標識符",
        "description": "對應客戶端 desc-?.tbl 中的多國語言字串編號 (例如：$xxxx)"
    },
    {
        "field": "classname",
        "annotation": "Class 類別路徑",
        "description": "獨立執行的 Class 類別路徑 (例如 com.lineage.data.npc.xxx)，用來綁定對話、動作或死亡時的特殊任務邏輯"
    },
    {
        "field": "impl",
        "annotation": "實作類型",
        "description": "定義該物件在核心中的實體物件類別 (例如：L1Monster、L1Merchant、L1Guard 等)"
    },
    {
        "field": "gfxid",
        "annotation": "外觀圖形編號",
        "description": "NPC 的外觀圖形編號 (Sprite ID)"
    },
    {
        "field": "lvl",
        "annotation": "等級",
        "description": "NPC 的基礎等級"
    },
    {
        "field": "hp",
        "annotation": "最大生命值",
        "description": "NPC 基礎最大生命值 (HP)"
    },
    {
        "field": "mp",
        "annotation": "最大魔力值",
        "description": "NPC 基礎最大魔力值 (MP)"
    },
    {
        "field": "ac",
        "annotation": "防禦力",
        "description": "NPC 基礎防禦力"
    },
    {
        "field": "str",
        "annotation": "力量",
        "description": "NPC 基礎力量屬性"
    },
    {
        "field": "con",
        "annotation": "體質",
        "description": "NPC 基礎體質屬性"
    },
    {
        "field": "dex",
        "annotation": "敏捷",
        "description": "NPC 基礎敏捷屬性"
    },
    {
        "field": "wis",
        "annotation": "精神",
        "description": "NPC 基礎精神屬性"
    },
    {
        "field": "intel",
        "annotation": "智力",
        "description": "NPC 基礎智力屬性"
    },
    {
        "field": "mr",
        "annotation": "魔法防禦力",
        "description": "NPC 的魔法防禦力 (抗魔)"
    },
    {
        "field": "exp",
        "annotation": "經驗值",
        "description": "擊殺後玩家可獲得的基礎經驗值"
    },
    {
        "field": "lawful",
        "annotation": "正義值",
        "description": "擊殺該 NPC 後，玩家會增加或減少的正義值"
    },
    {
        "field": "size",
        "annotation": "體型大小",
        "description": "體型大小，分為 large (大型) 或 small (小型)，影響武器大小怪傷害判定"
    },
    {
        "field": "weakAttr",
        "annotation": "弱點魔法屬性",
        "description": "害怕的魔法屬性。設定值如：1(地)、2(火)、4(水)、8(風)、-1(抗地) 等"
    },
    {
        "field": "ranged",
        "annotation": "攻擊距離",
        "description": "NPC 的攻擊距離 (格數)"
    },
    {
        "field": "tamable",
        "annotation": "可否迷魅/抓取",
        "description": "是否可以被玩家使用迷魅術或抓取為寵物 (true/false)"
    },
    {
        "field": "passispeed",
        "annotation": "移動速度",
        "description": "移動時的影格延遲時間"
    },
    {
        "field": "atkspeed",
        "annotation": "攻擊速度",
        "description": "物理攻擊時的影格延遲時間"
    },
    {
        "field": "atk_magic_speed",
        "annotation": "魔法攻擊速度",
        "description": "魔法攻擊時的影格延遲時間"
    },
    {
        "field": "sub_magic_speed",
        "annotation": "輔助魔法速度",
        "description": "施展輔助魔法時的影格延遲時間"
    },
    {
        "field": "undead",
        "annotation": "不死系屬性",
        "description": "不死系分類。0:無, 1:不死系, 2:惡魔系, 3:殭屍系, 4:特殊不死系(治癒術無傷害/不可起死回生), 5:狼人系, 6:龍系"
    },
    {
        "field": "poison_atk",
        "annotation": "毒屬性攻擊",
        "description": "是否帶有毒屬性攻擊"
    },
    {
        "field": "paralysis_atk",
        "annotation": "麻痺屬性攻擊",
        "description": "是否帶有麻痺屬性攻擊"
    },
    {
        "field": "agro",
        "annotation": "主動攻擊",
        "description": "是否為主動攻擊怪 (true/false)"
    },
    {
        "field": "agrososc",
        "annotation": "變形探知",
        "description": "是否會主動識破並攻擊變身的玩家"
    },
    {
        "field": "agrocoi",
        "annotation": "隱身探知",
        "description": "是否會主動發現並攻擊隱身的玩家"
    },
    {
        "field": "family",
        "annotation": "家族/群組",
        "description": "家族/群組名稱，用於設定同族群的互助機制"
    },
    {
        "field": "agrofamily",
        "annotation": "同族互助",
        "description": "同族互助設定。1 代表同種族會互相幫助；大於 1 代表會支援所有 NPC"
    },
    {
        "field": "agrogfxid1",
        "annotation": "變身圖形 ID 1",
        "description": "怪物被激怒或特定狀態下的變身圖形 ID (1)"
    },
    {
        "field": "agrogfxid2",
        "annotation": "變身圖形 ID 2",
