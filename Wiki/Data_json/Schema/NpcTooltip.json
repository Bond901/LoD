    {
        "field": "picupitem",
        "annotation": "撿取物品",
        "description": "怪物是否會撿取地上的物品 (true/false)"
    },
    {
        "field": "digestitem",
        "annotation": "消化物品時間",
        "description": "吃掉(消化)撿取道具所需的時間 (秒)"
    },
    {
        "field": "bravespeed",
        "annotation": "勇水狀態",
        "description": "怪物是否天生擁有勇氣藥水 (二段加速) 效果"
    },
    {
        "field": "hprinterval",
        "annotation": "HP 回復間隔",
        "description": "HP 自然回復的間隔時間"
    },
    {
